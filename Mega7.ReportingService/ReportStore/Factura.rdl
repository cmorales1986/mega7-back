        <Field Name="ValidTo">
          <DataField>ValidTo</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="InvoiceLines">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT
    Id,
    ARInvoiceId,
    ProductCode,
    ProductName,
    Quantity,
    UnitPrice,
    DiscountPercent,
    LineSubTotal,
    LineTax,
    LineTotal,
    BatchNumber,
    SerialNumbers
FROM ARInvoiceLines
WHERE ARInvoiceId = @invoiceId
ORDER BY Id
</CommandText>
        <QueryParameters>
          <QueryParameter Name="@invoiceId">
            <Value>=Parameters!invoiceId.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
