  <DataSources>
    <DataSource Name="DataSource1">
      <rd:SecurityType>DataBase</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=DESKTOP-KS945CF;Initial Catalog=Mega7;Encrypt=false;TrustServerCertificate=false;</ConnectString>
      </ConnectionProperties>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="InvoiceHeader">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT TOP 1
   a. Id,
   a.DocNumber,
   a.FiscalFullNumber,
   a.FiscalTimbrado,
    a.InvoiceDate,
    a.DueDate,
    a.CustomerName,
    a.SubTotal,
    a.TaxTotal,
    a.Total,
    a.Comments,
	a.PaymentType,
	a.CustomerId,
	b.RazonSocial,
	b.RUC,
	b.Contacto,
	b.Telefono,
	b.Direccion,
	b.Ciudad,
	c.TimbradoNumber,
	c.ValidTo
FROM ARInvoices a
INNER JOIN SociosNegocio b ON a.CustomerId = b.Id
LEFT JOIN FiscalDocumentSeries c ON a.FiscalSeriesId = c.Id
WHERE a.Id = @invoiceId
</CommandText>
        <QueryParameters>
          <QueryParameter Name="@invoiceId">
            <Value>=Parameters!invoiceId.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
